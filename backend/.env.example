PORT=5000
MONGO_URI=mongodb://localhost:27017/tradesphere
JWT_SECRET=supersecretjwtkey
NODE_ENV=development

# Production: frontend URL for CORS and Kite redirects (no trailing slash).
# FRONTEND_URL=https://your-app.vercel.app
# Or multiple origins, comma-separated:
# CORS_ORIGIN=https://your-app.vercel.app,https://www.your-app.vercel.app

# Optional: Live tick-by-tick data (TrueData). Sign up at https://www.truedata.in/products/marketdataapi
# TRUEDATA_USER=your_username
# TRUEDATA_PASSWORD=your_password
# TRUEDATA_PORT=8082

